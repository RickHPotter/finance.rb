<% if @card_transaction.errors.empty? %>
  <%= turbo_stream.update(:tabs, partial: "shared/v1/tabs") %>
  <%= turbo_stream.update(:notification, partial: "shared/flash", locals: { notice: notification_model(:updateda, CardTransaction) }) %>

  <%= turbo_stream.replace(:center_container, Views::V1::CardTransactions::Index.new(index_context: @index_context, mobile: @mobile)) %>
<% else %>
  <%= turbo_stream.update(:notification, partial: "shared/flash", locals: { alert: notification_model(:not_updateda, CardTransaction) }) %>

  <%= turbo_stream.replace(:center_container, Views::V1::CardTransactions::Edit.new(current_user:, card_transaction: @card_transaction)) %>
<% end %>
