<% if @card_transaction.destroyed? %>
  <%= turbo_stream.update(:tabs, partial: "shared/v1/tabs") %>
  <%= turbo_stream.update(:notification, partial: "shared/flash", locals: { notice: notification_model(:destroyeda, CardTransaction) }) %>

  <%= turbo_stream.replace(:center_container, Views::V1::CardTransactions::Index.new(index_context: @index_context, mobile: @mobile)) %>
<% else %>
  <%= turbo_stream.update(:notification, partial: "shared/flash", locals: { alert: notification_model(:not_destroyeda, CardTransaction) }) %>
<% end %>
