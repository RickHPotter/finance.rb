<% if @budget.valid? %>
  <%= turbo_stream.update(:tabs, partial: "shared/v1/tabs") if @budget.active? %>
  <%= turbo_stream.update(:notification, partial: "shared/flash", locals: { notice: notification_model(:updated, Budget) }) %>

  <%= turbo_stream.replace(:center_container, Views::V1::CashTransactions::Index.new(index_context: @index_context, mobile: @mobile)) %>
<% else %>
  <%= turbo_stream.update(:notification, partial: "shared/flash", locals: { alert: @budget.errors.full_messages&.join || notification_model(:not_updated, Budget) }) %>

  <%= turbo_stream.replace(:center_container, Views::V1::Budgets::Edit.new(current_user:, budget: @budget)) %>
<% end %>
