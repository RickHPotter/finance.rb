<% if @message.persisted? %>
  <%= turbo_stream.replace dom_id(@conversation, :messages) do %>
    <%= render Views::V1::Messages::Form.new(conversation: @conversation) %>
  <% end %>
<% else %>
  <%= turbo_stream.update(:notification, partial: "shared/flash", locals: { alert: notification_model(:not_createda, Message) }) %>
<% end %>
