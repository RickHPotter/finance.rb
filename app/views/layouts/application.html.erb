<!DOCTYPE html>
<html>
  <head>
    <title><%= t("pages.title") %></title>
    <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no">
    <meta name="theme-color" content="#1a202c">
    <meta name="mobile-web-app-capable" content="yes">
    <meta name="current-user-id" content="<%= current_user&.id %>">

    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <link rel="manifest" href="/manifest.json">
    <link rel="icon" href="/pwa_logos/128.png" type="image/png">
    <link rel="apple-touch-icon" href="/pwa_logos/512.png">

    <%= stylesheet_link_tag "tailwind", data: { turbo_track: :reload } %>
    <%= stylesheet_link_tag "application", data: { turbo_track: :reload } %>
    <%= stylesheet_link_tag "components/tom-select" %>
    <%= stylesheet_link_tag "components/select" %>
    <%= combobox_style_tag %>
    <%= javascript_include_tag "application", data: { turbo_track: :reload }, type: :module %>
  </head>

  <div data-controller="push"></div>

  <body class="h-screen bg-gray-900 text-white">
    <%= content_tag :main, class: "antialiased max-w-auto max-w-[1420px] mx-auto" do %>
      <%= turbo_frame_tag :notification do %>
        <%= render "shared/flash" %>
      <% end %>

      <%= content_tag :section, class: "mt-10 min-h-svh w-full" do %>
        <div class="w-full">
          <div class="flex justify-center mb-10">
            <div id="tabs" class="w-screen">
              <%= render "shared/tabs" %>
            </div>
          </div>

          <div class="mx-1 break-words bg-white shadow-md shadow-red-50 rounded-lg">
            <div class="p-1 md:p-2 lg:p-3">
              <div class="hidden relative" data-controller="price-sum">
                <div class="absolute -top-8 right-0 p-2 rounded-t-lg bg-yellow-400 shadow-md border border-yellow-600 font-lekton font-bold text-black text-md z-50">
                  <span id="totalPriceSum"></span>
                </div>
              </div>

              <%= render Views::Pages::Calculator.new %>

              <div class="text-center text-black pt-2">
                <%= yield %>
              </div>
            </div>
          </div>
        </div>
      <% end %>
    <% end %>
  </body>

  <footer class="antialiased pt-2 max-w-auto max-w-[1420px] mx-auto bg-gray-900 text-white">
    <div class="flex justify-between items-center">
      <div class="flex items-center gap-2">
        <span>
          <%= locale_link("pt-BR", class: "flex p-2 text-sm text-white hover:bg-gray-600") do %>
            <%= image_tag "https://cdn.icon-icons.com/icons2/1694/PNG/512/brbrazilflag_111698.png", size: "25x15", title: "Português" %>
          <% end %>
        </span>
        <span>
          <%= locale_link("en", class: "flex p-2 text-sm text-white hover:bg-gray-600") do %>
            <%= image_tag "https://static.vecteezy.com/system/resources/previews/005/416/914/original/flag-of-united-kingdom-illustration-free-vector.jpg", size: "25x15", title: "English" %>
          <% end %>
        </span>
      </div>

      <div class="flex gap-2">
        <div class="text-sm text-white hover:bg-gray-600">
          <%= link_to donation_pages_path, class: "flex items-center gap-2 p-2", data: { turbo_frame: :_top, turbo_prefetch: false } do %>
            <%= t(:donate) %>
            <%= render_icon(:heart) %>
          <% end %>
        </div>
        <% if current_user %>
          <div class="text-sm text-white hover:bg-gray-600">
            <%= link_to destroy_user_session_path, class: "flex items-center gap-2 p-2", data: { turbo_method: :delete } do %>
              <%= t(:sign_out) %>
              <%= render_icon(:leave) %>
            <% end %>
          </div>
        <% end %>
      </div>
    </div>

    <button data-controller="push" data-action="push#subscribe" class="pt-16 mb-2 text-xs flex mx-auto">
      🔔
    </button>

    <div class="flex md:hidden justify-center mb-2">
      <a class="flex items-center text-sm text-gray-600 hover:text-gray-500" href="https://rickhpotter.github.io/30fev_docs.ts/" target="_blank">
        <%= t("pages.docs") %>
      </a>
    </div>

    <div class="hidden md:flex justify-center mb-2">
      <a class="flex items-center text-sm text-gray-600 hover:text-gray-500" href="https://rickhpotter.github.io/30fev_docs.ts/" target="_blank">
        <%= t("pages.docs") %>
      </a>
    </div>

    <% if current_user %>
      <div class="hidden md:flex justify-center mb-2">
        <%= link_to "Download Backup", admin_data_backup_path, class: "text-sm text-indigo-700 hover:text-indigo-500" %>
      </div>
    <% end %>
  </footer>
</html>

<script>
  window.APP_LOCALE = "<%= I18n.locale %>"
  window.vapid_public_key = "<%= Rails.application.credentials.dig(:vapid, :public_key) %>"
</script>
