<%
  settings = Rails.application.config_for(:settings) || {}
  site = settings[:site] || settings["site"] || {}
%>
{
  "name": "<%= site[:name] || site["name"] || "30/Fev" %>",
  "short_name": "<%= site[:short_name] || site["short_name"] || "30/Fev" %>",
  "icons": [
    {
      "src": "/pwa_logos/512.png",
      "type": "image/png",
      "sizes": "512x512"
    },
    {
      "src": "/pwa_logos/512.png",
      "type": "image/png",
      "sizes": "512x512",
      "purpose": "maskable"
    }
  ],
  "start_url": "/",
  "id": "finance-rb",
  "display": "standalone",
  "scope": "/",
  "description": "<%= site[:description] || site["description"] || "A simple way to manage your finances" %>",
  "categories": "<%= site[:keywords] || site["keywords"] || "Finance, Budget, Money" %>",
  "theme_color": "#1a202c",
  "background_color": "#1a202c",
  "shortcuts": [
    {
      "name": "<%= t('pages.title') %>",
      "description": "<%= t('pages.subtitle') %>",
      "url": "<%= root_path %>"
    }
  ]
}
