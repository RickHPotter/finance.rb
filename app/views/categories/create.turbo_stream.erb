<% if @category.errors.empty? %>
  <% if @category.active? && @card_transaction %>
    <%= turbo_stream.update(:tabs, partial: "shared/tabs") %>
    <%= turbo_stream.update(:notification, partial: "shared/flash", locals: { notice: notification_model(:createda, Category) }) %>

    <%= turbo_stream.replace(:center_container, Views::CardTransactions::New.new(current_user:, card_transaction: @card_transaction)) %>
  <% else %>
    <%= turbo_stream.replace(:center_container, Views::Categories::Index.new(categories: @categories, mobile: @mobile)) %>
  <% end %>
<% else %>
  <%= turbo_stream.update(:notification, partial: "shared/flash", locals: { alert: notification_model(:not_createda, Category) }) %>

  <%= turbo_stream.replace(:center_container, Views::Categories::New.new(current_user:, category: @category)) %>
<% end %>
