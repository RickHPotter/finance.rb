<% if @category.destroyed? %>
  <%= turbo_stream.update(:notification, partial: "shared/flash", locals: { notice: notification_model(:destroyeda, Category) }) %>

  <%= turbo_stream.replace(:center_container, template: "categories/index") %>
<% else %>
  <%= turbo_stream.update(:notification, partial: "shared/flash", locals: { alert: notification_model(:not_destroyed_because_has_transactionsa, Category) }) %>
<% end %>
