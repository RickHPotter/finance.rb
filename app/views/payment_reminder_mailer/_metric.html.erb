<td width="33.33%" class="metric-cell" style="width: 33.33%; background: #111827; padding: 18px 14px; text-align: center;">
  <div style="color: <%= color %> !important; font-size: 30px; font-weight: 900; line-height: 1;"><%= value %></div>
  <div style="margin-top: 8px; color: #cbd5e1 !important; font-size: 10px; font-weight: 800; letter-spacing: 0.14em; text-transform: uppercase;"><%= label %></div>
</td>
