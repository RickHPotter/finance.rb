<%= t("payment_reminder_mailer.daily_digest.preview_title") %>

<%= t("payment_reminder_mailer.daily_digest.sections.overdue.title") %>
<% @overdue.each do |installment| %>
- <%= installment.cash_transaction.description %> | <%= l(installment.date.to_date, format: :long) %> | <%= number_to_currency(installment.price.abs / 100.0, unit: "R$ ", separator: ",", delimiter: ".") %> | <%= installment.number %>/<%= installment.cash_installments_count %>
<% end %>

