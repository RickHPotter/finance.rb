<% if @user_bank_account.errors.empty? %>
  <% if @user_bank_account.active? && @cash_transaction %>
    <%= turbo_stream.update(:tabs, partial: "shared/tabs") %>
    <%= turbo_stream.update(:notification, partial: "shared/flash", locals: { notice: notification_model(:updateda, UserBankAccount) }) %>

    <%= turbo_stream.replace(:center_container, Views::CashTransactions::New.new(current_user:, cash_transaction: @cash_transaction)) %>
  <% else %>
    <%= turbo_stream.replace(:center_container, template: "user_bank_accounts/index") %>
  <% end %>
<% else %>
  <%= turbo_stream.update(:notification, partial: "shared/flash", locals: { alert: notification_model(:not_updateda, UserBankAccount) }) %>

  <%= turbo_stream.replace(:center_container, template: "user_bank_accounts/edit", locals: { user_bank_account: @user_bank_account }) %>
<% end %>
