<% if @user_bank_account.destroyed? %>
  <%= turbo_stream.update(:tabs, partial: "shared/tabs") %>
  <%= turbo_stream.update(:notification, partial: "shared/flash", locals: { notice: notification_model(:destroyeda, UserBankAccount) }) %>

  <%= turbo_stream.replace(:center_container, Views::UserBankAccounts::Index.new(user_bank_accounts: @user_bank_accounts, mobile: @mobile)) %>
<% else %>
  <%= turbo_stream.update(:notification, partial: "shared/flash", locals: { alert: notification_model(:not_destroyed_because_has_transactionsa, UserBankAccount) }) %>
<% end %>
