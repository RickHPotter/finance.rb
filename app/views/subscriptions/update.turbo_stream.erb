<% if @subscription.errors.empty? %>
  <%= turbo_stream.update(:tabs, partial: "shared/tabs") %>
  <%= turbo_stream.update(:notification, partial: "shared/flash", locals: { notice: notification_model(:updated, Subscription) }) %>

  <%= turbo_stream.replace(:center_container, Views::Subscriptions::Index.new(subscriptions: @subscriptions, mobile: @mobile)) %>
<% else %>
  <%= turbo_stream.update(:notification, partial: "shared/flash", locals: { alert: notification_model(:not_updated, Subscription) }) %>

  <%= turbo_stream.replace(:center_container, Views::Subscriptions::Edit.new(current_user:, subscription: @subscription)) %>
<% end %>
