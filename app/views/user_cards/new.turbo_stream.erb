<%= turbo_stream.update(:tabs, partial: "shared/tabs") %>

<%= turbo_stream.replace(:center_container, Views::UserCards::New.new(current_user:, user_card: @user_card, cards: @cards)) %>

<% if params[:no_user_card] %>
  <%= turbo_stream.update(:notification, partial: "shared/flash", locals: { notice: notification_model(:user_card_needed, CardTransaction) }) %>
<% end %>
