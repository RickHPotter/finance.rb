<% if @entity.destroyed? %>
  <%= turbo_stream.update(:notification, partial: "shared/flash", locals: { notice: notification_model(:destroyeda, Entity) }) %>

  <%= turbo_stream.replace(:center_container, Views::Entities::Index.new(entities: @entities, mobile: @mobile)) %>
<% else %>
  <%= turbo_stream.update(:notification, partial: "shared/flash", locals: { alert: notification_model(:not_destroyed_because_has_transactionsa, Entity) }) %>
<% end %>
