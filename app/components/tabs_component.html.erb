<% if @dependent %>
  <div class="opacity-<%= @default ? 100 : 0 %>" role="tabpanel" id="tab-item-<%= @dependent_no %>">
<% else %>
  <div <%= "data-controller=material-tailwind-tab data-load-on-empty-content=center_container" unless @dependent %>>
<% end %>
  <ul class="relative flex list-none rounded-xl p-1 overflow-x-auto"
      data-tabs="tabs" data-default="<%= @default %>" data-material-tailwind-tab-target="tabList"
      role="list">

    <% extra_data = @dependent ? { action: "click->material-tailwind-tab#updateParentLink", parent_id: @dependent_no } : {} %>
    <% @items.each_with_index do |item, index| %>
      <%= content_tag :li, class: "ring-1 rounded-lg ring-gray-800 scale-75 md:scale-100 z-30 flex-auto text-center w-1/#{@items.count}", data: { material_tailwind_tab_target: :tabItem } do %>
        <%= link_to item.link,
                    role: "tab",
                    aria: { selected: item.default, controls: "tab-item-#{index}" },
                    class: "z-30 mb-0 flex items-center justify-center rounded-lg border-0 bg-inherit px-4 py-1 transition-all ease-in-out",
                    data: { turbo_frame: item.turbo_frame, turbo_prefetch: false, material_tailwind_tab_target: "tabLink", id: index, **extra_data },
                    tabindex: "-1" do %>

            <% notification = "bg-orange-500" if item.notification_type == 1 %>
            <% notification = "bg-red-500" if item.notification_type == 2 %>

            <% if notification %>
              <span class="absolute flex size-3 z-30 left-3 pointer-events-none">
                <span class="relative inline-flex h-full w-full animate-ping rounded-full bg-red-400 opacity-75"></span>
                <span class="absolute inline-flex rounded-full size-3 <%= notification %>">
                </span>
              </span>
            <% end %>

            <%= content_tag :span, class: "pointer-events-none" do %>
              <%= helpers.render_icon item.icon %>
            <% end %>

            <%= content_tag :span, item.label, class: "ml-1 pointer-events-none text-slate-100 md:text-md md:font-bold text-nowrap text-sm font-light" %>
          <% end %>
        <% end %>
    <% end %>
  </ul>

  <% if @dependents.present? %>
    <div data-tab-content="">
      <% @dependents.each_with_index do |partial, index| %>
        <% current_index_is_default = @items.index(&:default) == index %>

        <%= render Components::TabsComponent.new(items: [ partial ], default: current_index_is_default, dependent: true, dependent_no: index, mobile: @mobile) %>
      <% end %>
    </div>
  <% end %>
</div>
